# Application identity and runtime mode.
BEEBHAI_APP_NAME=BeemBhai
BEEBHAI_ENVIRONMENT=development
BEEBHAI_APP_VERSION=0.1.0
BEEBHAI_SECRET_KEY=change-me
BEEBHAI_PUBLIC_BASE_URL=http://localhost:8000

# Postgres credentials used by the database container and app connection string.
POSTGRES_DB=beembhai
POSTGRES_USER=beembhai
POSTGRES_PASSWORD=change-me-postgres-password

# Internal service URLs used by the app and workers.
DATABASE_URL=postgresql+psycopg://beembhai:change-me-postgres-password@postgres:5432/beembhai
REDIS_URL=redis://redis:6379/0
RABBITMQ_DEFAULT_USER=beembhai
RABBITMQ_DEFAULT_PASS=change-me-rabbitmq-password
RABBITMQ_URL=amqp://beembhai:change-me-rabbitmq-password@rabbitmq:5672/

# MinIO root credentials and app-side secure storage settings.
MINIO_ROOT_USER=beembhai
MINIO_ROOT_PASSWORD=change-me-minio-password
MINIO_ENDPOINT=http://minio:9000
MINIO_ACCESS_KEY=beembhai
MINIO_SECRET_KEY=change-me-minio-password
MINIO_SECURE_STORAGE_BUCKET=secure-storage

# Langfuse self-hosting and runtime tracing settings.
# The base URL below is for containerized runtimes; host-side tools can override it to
# http://localhost:3000 if needed.
LANGFUSE_BASE_URL=http://langfuse-web:3000
LANGFUSE_PUBLIC_KEY=replace-with-langfuse-public-key
LANGFUSE_SECRET_KEY=replace-with-langfuse-secret-key
LANGFUSE_NEXTAUTH_SECRET=change-me-langfuse-nextauth-secret
LANGFUSE_POSTGRES_DB=langfuse
LANGFUSE_POSTGRES_USER=langfuse
LANGFUSE_POSTGRES_PASSWORD=change-me-langfuse-postgres-password
LANGFUSE_REDIS_PASSWORD=change-me-langfuse-redis-password
LANGFUSE_CLICKHOUSE_PASSWORD=change-me-langfuse-clickhouse-password
LANGFUSE_MINIO_ROOT_USER=langfuse
LANGFUSE_MINIO_ROOT_PASSWORD=change-me-langfuse-minio-password
LANGFUSE_INIT_ORG_NAME=BeemBhai
LANGFUSE_INIT_PROJECT_NAME=BeemBhai
LANGFUSE_INIT_PROJECT_PUBLIC_KEY=replace-with-langfuse-project-public-key
LANGFUSE_INIT_PROJECT_SECRET_KEY=replace-with-langfuse-project-secret-key
LANGFUSE_INIT_USER_EMAIL=admin@example.com
LANGFUSE_INIT_USER_NAME=BeemBhai
LANGFUSE_INIT_USER_PASSWORD=change-me-langfuse-admin-password

# Brevo email provider settings for outbound notifications.
BREVO_API_KEY=
BREVO_SENDER_EMAIL=no-reply@example.com
BREVO_SENDER_NAME=BeemBhai

JIRA_URL=https://your-domain.atlassian.net/
JIRA_USERNAME=admin@example.com
JIRA_API_TOKEN=your-jira-api-token
TOOLSETS=all
GH_TOKEN=your-github-token
EMAIL_BREVO_API_KEY=your-brevo-api-key
EMAIL_PROVIDER=brevo
EMAIL_FROM_ADDRESS=no-reply@example.com
