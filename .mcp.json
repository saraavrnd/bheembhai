{
    "mcpServers": {
        "atlassian": {
            "command": "uvx",
            "args": [
                "mcp-atlassian"
            ],
            "env": {
                "JIRA_URL": "${JIRA_URL}",
                "JIRA_USERNAME": "${JIRA_USERNAME}",
                "JIRA_API_TOKEN": "${JIRA_API_TOKEN}"
            }
        },
        "github": {
            "command": "npx",
            "args": [
                "-y",
                "@modelcontextprotocol/server-github"
            ],
            "env": {
                "GITHUB_PERSONAL_ACCESS_TOKEN": "${GH_TOKEN}"
            }
        }
    }
}